{
  "name": "orion",
  "version": "1.0.0",
  "author": "R. Poltera",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run react-start\" \"npm run electron-dev\"",
    "electron-dev": "wait-on http://localhost:3000 && wait-on http://localhost:3001 && electron .",
    "server": "node server/index.js",
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "build": "npm run react-build && electron-builder build --win",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.orionmediaserver.app",
    "productName": "Orion Media Server",
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "server/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "C:/Program Files/nodejs/node.exe",
        "to": "node/node.exe"
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*",
      "server/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "framer-motion": "^10.16.5",
    "lucide-react": "^0.263.1",
    "m3u-parser-generator": "^1.4.1",
    "multer": "^1.4.5-lts.1",
    "ffmpeg-static": "^5.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-player": "^2.13.0",
    "react-router-dom": "^6.18.0",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "react-scripts": "5.0.1",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  }
}
